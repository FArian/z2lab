{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npx tsc *)",
      "Bash(npx vitest *)",
      "Bash(npx prisma *)",
      "Bash(npx next *)",
      "Bash(npx vercel *)",
      "Bash(npx ts-node *)",
      "Bash(docker compose *)",
      "Bash(docker buildx *)",
      "Bash(docker ps)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(git describe *)",
      "Bash(git rev-parse *)",
      "Bash(git rev-list *)",
      "Bash(git ls-files *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh api *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(node scripts/*)",
      "Bash(node generate_fhir_resources.mjs)",
      "Bash(node generate_conceptmap.mjs)",
      "Bash(sqlite3 data/*.db SELECT*)",
      "Bash(sqlite3 frontend/orderentry/data/*.db SELECT*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -fsS http://localhost:*)",
      "WebSearch",
      "WebFetch(domain:hl7.org)",
      "WebFetch(domain:fhir.org)",
      "WebFetch(domain:terminology.hl7.org)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:prisma.io)",
      "WebFetch(domain:opentelemetry.io)",
      "WebFetch(domain:swagger.io)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-check-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  }
}
