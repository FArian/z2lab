# =============================================================================
# z2Lab OrderEntry — Umgebungsvariablen
# =============================================================================
#
# Kopiere diese Datei nach docker/.env und passe die Werte an:
#   cp docker/.env.example docker/.env
#
# Naming-Konvention: ORDERENTRY_<SERVICE>__<KEY>
# Ausnahmen (Framework-Constraints): DATABASE_URL, NODE_ENV, NEXT_PUBLIC_*
# =============================================================================

# ── Docker Image & Port ──────────────────────────────────────────────────────
IMAGE=farian/orderentry:latest
PORT=3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Mindestens 32 Zeichen — generieren mit: openssl rand -hex 32
ORDERENTRY_AUTH__SECRET=change-me-min-32-chars-use-openssl-rand-hex-32
ORDERENTRY_AUTH__ALLOW_LOCAL=false
ORDERENTRY_AUTH__SESSION_IDLE_TIMEOUT=30

# ── Datenbank ─────────────────────────────────────────────────────────────────
# sqlite | postgresql | sqlserver
ORDERENTRY_DB__PROVIDER=sqlite
DATABASE_URL=file:/app/data/orderentry.db

# ── Bootstrap Admin (nur erster Start) ───────────────────────────────────────
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin1234!

# ── FHIR Server ───────────────────────────────────────────────────────────────
ORDERENTRY_FHIR__BASE_URL=https://hapi.fhir.org/baseR4

# ── FHIR Auth (Standard: none) ───────────────────────────────────────────────
# none | bearer | basic | apiKey | oauth2 | digest
ORDERENTRY_FHIR__AUTH_TYPE=none
#ORDERENTRY_FHIR__AUTH_TOKEN=
#ORDERENTRY_FHIR__AUTH_USER=
#ORDERENTRY_FHIR__AUTH_PASSWORD=

# ── FHIR Seed ─────────────────────────────────────────────────────────────────
# Stammdaten beim Start automatisch laden (idempotent)
ORDERENTRY_FHIR__SEED_ENABLED=true
# Demo-Daten laden (nur Entwicklung — nie in Produktion!)
ORDERENTRY_FHIR__SEED_DEMO=false
# Test-Katalog laden (20 gemischte ROUTINE/MIBI Tests — für Dev/Demo)
ORDERENTRY_FHIR__SEED_CATALOG=false

# ── FHIR Identifier-Systeme (Schweizer Standards — Defaults meist korrekt) ───
#ORDERENTRY_FHIR__SYSTEM_GLN=https://www.gs1.org/gln
#ORDERENTRY_FHIR__SYSTEM_AHV=urn:oid:2.16.756.5.32
#ORDERENTRY_FHIR__SYSTEM_VEKA=urn:oid:2.16.756.5.30.1.123.100.1.1
#ORDERENTRY_FHIR__SYSTEM_CATEGORY=https://www.zetlab.ch/fhir/category

# ── Labor / Organisation ─────────────────────────────────────────────────────
ORDERENTRY_LAB__ORG_ID=zlz
ORDERENTRY_LAB__NAME=ZLZ Zentrallabor AG
# Interne FHIR Org-IDs (Zugriff Level A — kein Filter)
ORDERENTRY_LAB__INTERNAL_ORG_IDS=zlz,zetlab,zlz-notfall

# ── SNOMED Codes (Defaults meist korrekt — nur ändern wenn nötig) ─────────────
# PractitionerRole-Codes für Zugriffssteuerung
#ORDERENTRY_SNOMED__ROLE_INTERNAL=159418007,159011000
#ORDERENTRY_SNOMED__ROLE_ORG_ADMIN=224608005,394572006
#ORDERENTRY_SNOMED__ROLE_PHYSICIAN=309343006,59058001,106289002
# Organization-Type-Codes
#ORDERENTRY_SNOMED__ORG_LABORATORY=708175003
#ORDERENTRY_SNOMED__ORG_HOSPITAL=22232009
#ORDERENTRY_SNOMED__ORG_OUTPATIENT=33022008
#ORDERENTRY_SNOMED__ORG_HOLDING=224891009

# ── Orchestra (optional) ──────────────────────────────────────────────────────
# Generieren mit: openssl rand -hex 32
#ORDERENTRY_ORCHESTRA__JWT_SECRET=
#ORDERENTRY_ORCHESTRA__HL7_BASE=http://orchestra:8019
#ORDERENTRY_ORCHESTRA__ORDER_API_URL=http://orchestra:8019/api/v1/orders/number

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error | silent
ORDERENTRY_LOG__LEVEL=info
ORDERENTRY_LOG__FILE=/app/logs/zetlab.log

# ── Observability (optional) ─────────────────────────────────────────────────
ORDERENTRY_TRACING__ENABLED=false
#ORDERENTRY_TRACING__URL=http://jaeger:4318
#ORDERENTRY_TRACING__LABEL=Jaeger
#ORDERENTRY_MONITORING__URL=http://grafana:3000
#ORDERENTRY_MONITORING__LABEL=Grafana
# Generieren mit: openssl rand -hex 32
#ORDERENTRY_METRICS__TOKEN=

# ── Mail (optional) ───────────────────────────────────────────────────────────
# smtp | hin | smtp_oauth2 | google_workspace_relay
#ORDERENTRY_MAIL__PROVIDER=smtp
#ORDERENTRY_MAIL__HOST=mail.example.ch
#ORDERENTRY_MAIL__PORT=587
#ORDERENTRY_MAIL__USER=noreply@example.ch
#ORDERENTRY_MAIL__PASSWORD=
#ORDERENTRY_MAIL__FROM=OrderEntry <noreply@example.ch>

# ── SQL Server (nur mit docker-compose.sqlserver.yml) ────────────────────────
#MSSQL_SA_PASSWORD=YourStrong!Password
#ORDERENTRY_DB_PASSWORD=OrderEntry1!
