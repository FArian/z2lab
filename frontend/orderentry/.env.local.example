# ============================================================
# ZetLab OrderEntry — .env.local (Windows Dev)
# ============================================================
# Kopiere diese Datei nach .env.local und passe die Werte an.
# .env.local wird NIEMALS committed (steht in .gitignore).
#
# Naming Convention:  <APP_NAME>_<SERVICE>__<KEY>
#   APP_NAME  = Pflicht-Prefix (Standard: ORDERENTRY)
#   SERVICE   = logischer Bereich (FHIR, AUTH, LOG, …)
#   __        = Doppel-Unterstrich trennt SERVICE von KEY
#
# Beispiel: ORDERENTRY_FHIR__BASE_URL
#
# Ändere nur APP_NAME und alle anderen ENV-Variablen
# folgen automatisch dem neuen Prefix.
#
# Priorität in Next.js:
#   .env.local  >  .env.development  >  .env
# Änderungen wirken nach: npm run dev (Neustart)
# ============================================================


# ════════════════════════════════════════════════════════════
# APP IDENTIFIKATION (Pflicht — bestimmt den Prefix)
# ════════════════════════════════════════════════════════════

# Name der Anwendung — wird als Prefix für ALLE anderen ENV-Variablen verwendet.
# Änderung hier benennt alle Variablen automatisch um (kein Code-Umbau nötig).
# Standard: ORDERENTRY  → ergibt Prefix ORDERENTRY_
APP_NAME=ORDERENTRY

# Deployment-Umgebung (dokumentarisch — Next.js trennt via Datei-Priorität)
ENV=DEV


# ════════════════════════════════════════════════════════════
# FHIR  →  ORDERENTRY_FHIR__*
# ════════════════════════════════════════════════════════════

# Basis-URL des HAPI FHIR R4 Servers.
# Alle FHIR-Proxy-Routen (/api/v1/proxy/fhir/*) verwenden diese URL.
# Option A — Lokaler Docker Desktop:
ORDERENTRY_FHIR__BASE_URL=http://localhost:8080/fhir
# Option B — Remote HAPI via Tunnel (nip.io / Cloudflare):
# ORDERENTRY_FHIR__BASE_URL=https://hapi.2a01-4f8-1c1a-5842--1.nip.io/fhir

# FHIR System-URI für GS1 Global Location Number (GLN).
# Wird verwendet um Practitioner und Organization anhand der GLN zu suchen.
# Nur ändern wenn dein HAPI FHIR einen anderen System-URI verwendet.
# ORDERENTRY_FHIR__SYSTEM_GLN=https://www.gs1.org/gln

# FHIR System-URI für die Schweizer AHV/AVS-Sozialversicherungsnummer.
# ORDERENTRY_FHIR__SYSTEM_AHV=urn:oid:2.16.756.5.32

# FHIR System-URI für die Schweizer VeKa-Krankenversicherungskartennummer.
# ORDERENTRY_FHIR__SYSTEM_VEKA=urn:oid:2.16.756.5.30.1.123.100.1.1

# FHIR System-URI für das santésuisse Zahlstellenregister (ZSR).
# ORDERENTRY_FHIR__SYSTEM_ZSR=urn:oid:2.16.756.5.30.1.123.100.2.1.1

# FHIR System-URI für die Schweizer Unternehmens-Identifikation (UID / CHE-Nummer).
# ORDERENTRY_FHIR__SYSTEM_UID=urn:oid:2.16.756.5.35

# FHIR System-URI für die Schweizer Betriebseinheitsnummer BFS (BUR).
# ORDERENTRY_FHIR__SYSTEM_BUR=urn:oid:2.16.756.5.45

# FHIR System-URI für ZetLab-Servicekategorien in ActivityDefinition.topic.coding.
# Wird von GET /api/v1/config/service-types verwendet um MIBI/ROUTINE/POC zu erkennen.
# ORDERENTRY_FHIR__SYSTEM_CATEGORY=https://www.zetlab.ch/fhir/category

# FHIR Outbound-Auth — wie sich OrderEntry beim HAPI FHIR authentifiziert.
# none = kein Auth (Standard für internes Docker-Netzwerk, empfohlen für Dev).
# Typen: none | bearer | basic | apiKey | oauth2 | digest
# Konfigurierbar über Admin → Auth-Konfiguration (/admin/auth-config).
ORDERENTRY_FHIR__AUTH_TYPE=none

# -- Bearer Token (AUTH_TYPE=bearer) -----------------------------------------
# ORDERENTRY_FHIR__AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -- Basic / Digest Auth (AUTH_TYPE=basic oder digest) -----------------------
# ORDERENTRY_FHIR__AUTH_USER=admin
# ORDERENTRY_FHIR__AUTH_PASSWORD=changeme

# -- API Key (AUTH_TYPE=apiKey) -----------------------------------------------
# ORDERENTRY_FHIR__AUTH_API_KEY_NAME=X-Api-Key
# ORDERENTRY_FHIR__AUTH_API_KEY_VALUE=my-api-key
# ORDERENTRY_FHIR__AUTH_API_KEY_LOCATION=header

# -- OAuth2 Client Credentials (AUTH_TYPE=oauth2) — z.B. Keycloak SMART on FHIR
# ORDERENTRY_FHIR__AUTH_CLIENT_ID=z2lab-backend
# ORDERENTRY_FHIR__AUTH_CLIENT_SECRET=changeme-generate-with-openssl-rand-hex-32
# ORDERENTRY_FHIR__AUTH_TOKEN_URL=https://keycloak.localhost/realms/z2lab/protocol/openid-connect/token
# ORDERENTRY_FHIR__AUTH_SCOPES=fhir/read fhir/write


# ════════════════════════════════════════════════════════════
# AUTHENTIFIZIERUNG  →  ORDERENTRY_AUTH__*
# ════════════════════════════════════════════════════════════

# HMAC-SHA256 Signing-Secret für Session-Cookies.
# Alle Browser-Sessions werden mit diesem Schlüssel signiert und verifiziert.
# Mindestens 32 Zeichen — in Produktion mit: openssl rand -hex 32
ORDERENTRY_AUTH__SECRET=dev-secret-change-me-before-production

# Erlaubt den unsignierten localSession-Cookie als Auth-Fallback im Browser.
# true = Dev ohne Passwort möglich (localStorage-Auth).
# NIEMALS true in Produktion setzen.
ORDERENTRY_AUTH__ALLOW_LOCAL=true

# Automatische Abmeldung nach Inaktivität in Minuten.
# 0 = deaktiviert (empfohlen für Dev). Produktion: 15–30 Minuten.
ORDERENTRY_AUTH__SESSION_IDLE_TIMEOUT=0


# ════════════════════════════════════════════════════════════
# ORCHESTRA  →  ORDERENTRY_ORCHESTRA__*
# ════════════════════════════════════════════════════════════

# Gemeinsames HS256-Secret für JWT-Validierung von Orchestra (/api/launch).
# Nur nötig wenn die Orchestra-Launch-Integration getestet wird.
# Generieren: openssl rand -hex 32
# ORDERENTRY_ORCHESTRA__JWT_SECRET=dev-orchestra-secret

# Basis-URL der Orchestra HL7-API.
# Leer lassen wenn Orchestra nicht lokal läuft — HL7-Proxy ist dann deaktiviert.
# ORDERENTRY_ORCHESTRA__HL7_BASE=http://localhost:8019

# Orchestra API-URL für automatische Auftragsnummer-Generierung.
# Leer lassen = Pool-Fallback (SQLite-Pool) wird direkt verwendet.
# ORDERENTRY_ORCHESTRA__ORDER_API_URL=http://localhost:8090

# HTTP-Timeout für Orchestra Auftragsnummer-Requests in Millisekunden.
# ORDERENTRY_ORCHESTRA__ORDER_TIMEOUT_MS=3000

# HL7 Inbound/Outbound Pfade auf Orchestra (Standard passt für OIE Juno 4.x)
# ORDERENTRY_ORCHESTRA__HL7_INBOUND_PATH=/api/v1/in/hl7
# ORDERENTRY_ORCHESTRA__HL7_OUTBOUND_PATH=/api/v1/out/hl7


# ════════════════════════════════════════════════════════════
# DATENBANK  →  ORDERENTRY_DB__*
# ════════════════════════════════════════════════════════════

# Datenbank-Engine für den User-Store (Benutzer, Rollen, Agent-Jobs, Org-Regeln).
# sqlite   = eingebettet, keine extra Installation (Standard für Dev)
# postgresql = externe PostgreSQL-Instanz
# sqlserver  = Microsoft SQL Server
ORDERENTRY_DB__PROVIDER=sqlite

# Verbindungs-String zur Datenbank.
# ACHTUNG: DATABASE_URL behält diesen Namen — Prisma liest ihn direkt (Framework-Constraint).
# SQLite: relativer Pfad ab frontend/zetlab/ — Datei wird automatisch erstellt.
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=file:./data/orderentry.db

# Benutzername des ersten Admin-Users — wird beim Start automatisch erstellt
# wenn noch kein Admin in der Datenbank existiert.
# ACHTUNG: BOOTSTRAP_* werden direkt von src/lib/userStore.ts gelesen (Legacy).
BOOTSTRAP_ADMIN_USER=admin

# Passwort des ersten Admin-Users.
# Sofort nach dem ersten Login ändern!
BOOTSTRAP_ADMIN_PASSWORD=Admin1234!


# ════════════════════════════════════════════════════════════
# LOGGING  →  ORDERENTRY_LOG__*
# ════════════════════════════════════════════════════════════

# Minimaler Log-Level der Konsolen-Ausgabe.
# debug = alle Meldungen (empfohlen für Dev)
# info  = normale Betriebsmeldungen (Produktion)
# warn  = nur Warnungen und Fehler
# error = nur Fehler
# silent = keine Ausgabe
ORDERENTRY_LOG__LEVEL=debug

# Absoluter Pfad zur Log-Datei (strukturiertes JSON, append-only).
# Leer lassen = nur Konsolen-Ausgabe, keine Datei.
# Windows-Hinweis: /tmp funktioniert auf Windows NICHT — absoluten Pfad verwenden.
ORDERENTRY_LOG__FILE=C:/tmp/zetlab.log


# ════════════════════════════════════════════════════════════
# OBSERVABILITY  →  ORDERENTRY_TRACING__* / ORDERENTRY_MONITORING__*
# ════════════════════════════════════════════════════════════

# OpenTelemetry Distributed Tracing aktivieren.
# false = deaktiviert (Standard für Dev — kein Jaeger/Tempo nötig).
# true  = ORDERENTRY_TRACING__URL muss gesetzt sein.
ORDERENTRY_TRACING__ENABLED=false

# OTLP/HTTP Collector-URL für Distributed Tracing.
# Nur relevant wenn ORDERENTRY_TRACING__ENABLED=true.
# Lokal mit Jaeger: http://localhost:4318
# ORDERENTRY_TRACING__URL=http://localhost:4318

# Anzeigename des Tracing-Systems (z.B. Jaeger, Tempo, Zipkin).
# Wird in Admin → System als Label angezeigt.
# ORDERENTRY_TRACING__LABEL=Jaeger

# URL des Monitoring-Dashboards (z.B. Grafana).
# Wird nur als klickbarer Link in der Settings-Seite angezeigt — kein API-Aufruf.
# ORDERENTRY_MONITORING__URL=http://localhost:3001

# Anzeigename des Monitoring-Systems.
# ORDERENTRY_MONITORING__LABEL=Grafana

# Prometheus Scraper Bearer-Token für GET /api/metrics.
# Leer = Standard Admin-Auth wird verwendet.
# Generieren: openssl rand -hex 32
# ORDERENTRY_METRICS__TOKEN=changeme-generate-with-openssl-rand-hex-32


# ════════════════════════════════════════════════════════════
# EXTERNE APIs  →  ORDERENTRY_SASIS__* / ORDERENTRY_REFDATA__*
# ════════════════════════════════════════════════════════════

# SOAP-Endpoint der offiziellen Schweizer RefData-Datenbank für GLN-Abfragen.
# Wird von GET /api/v1/gln-lookup verwendet.
# Default zeigt auf Produktion — kein Override nötig ausser für Tests mit Mock.
# ORDERENTRY_REFDATA__SOAP_URL=https://refdatabase.refdata.ch/Service/Partner.asmx

# Basis-URL des SASIS/OFAC VeKa-Karten-Lookup API (via Orchestra-Middleware).
# Leer lassen wenn Orchestra nicht lokal läuft.
# ORDERENTRY_SASIS__API_BASE=http://localhost:8019/middleware/sasis


# ════════════════════════════════════════════════════════════
# AUFTRAGSNUMMERN  →  ORDERENTRY_ORDER__*
# ════════════════════════════════════════════════════════════

# Komma-getrennte Liste der aktiven Auftragstypen.
# Überschreibt die automatische FHIR-Erkennung via ActivityDefinition.topic.
# Leer lassen = Typen werden live aus FHIR gelesen (5-Min-Cache), empfohlen.
# ORDERENTRY_ORDER__SERVICE_TYPES=MIBI,ROUTINE,POC

# MIBI Auftragsnummer-Format (Standard: MI4XXXXXXXX, 10 Stellen gesamt)
# ORDERENTRY_ORDER__MI_PREFIX=MI
# ORDERENTRY_ORDER__MI_START=4
# ORDERENTRY_ORDER__MI_LENGTH=10

# ROUTINE Auftragsnummer-Format (Standard: 10-stellig numerisch)
# ORDERENTRY_ORDER__ROUTINE_LENGTH=10

# POC Auftragsnummer-Format (Standard: POXXXXX, 7 Stellen gesamt)
# ORDERENTRY_ORDER__POC_PREFIX=PO
# ORDERENTRY_ORDER__POC_LENGTH=7


# ════════════════════════════════════════════════════════════
# POOL-SCHWELLENWERTE  →  ORDERENTRY_POOL__*
# ════════════════════════════════════════════════════════════

# E-Mail-Benachrichtigung wenn Auftragsnummern-Pool unter Schwellenwert fällt.
# ORDERENTRY_POOL__INFO_THRESHOLD=50
# ORDERENTRY_POOL__WARN_THRESHOLD=20
# ORDERENTRY_POOL__ERROR_THRESHOLD=5
# ORDERENTRY_POOL__NOTIFICATION_EMAIL=admin@zetlab.ch


# ════════════════════════════════════════════════════════════
# DEEP LINKING  →  ORDERENTRY_DEEPLINK__*
# ════════════════════════════════════════════════════════════

# KIS/PIS → OrderEntry Workflow-Integration via signiertem Token.
ORDERENTRY_DEEPLINK__ENABLED=false
ORDERENTRY_DEEPLINK__AUTH_TYPE=jwt
# ORDERENTRY_DEEPLINK__JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
# ORDERENTRY_DEEPLINK__HMAC_SECRET=changeme-generate-with-openssl-rand-hex-32
# ORDERENTRY_DEEPLINK__TOKEN_MAX_AGE_SECONDS=300
# ORDERENTRY_DEEPLINK__ALLOWED_SYSTEMS=kis-system-1,pis-system-2


# ════════════════════════════════════════════════════════════
# E-MAIL  →  ORDERENTRY_MAIL__*
# ════════════════════════════════════════════════════════════
# Ausgehende E-Mails für Benachrichtigungen, Passwort-Reset und
# (mit HIN) verschlüsselte Laborbefund-Zustellung gemäss nDSG.
#
# ORDERENTRY_MAIL__PROVIDER: smtp | gmail | smtp_oauth2 | google_workspace_relay
# ORDERENTRY_MAIL__AUTH_TYPE: APP_PASSWORD | OAUTH2 | NONE
# Leer lassen = Mail komplett deaktiviert.
# ════════════════════════════════════════════════════════════

# -- SMTP + App Password (generischer Mailserver / Exchange / Hospital Relay) --
# ORDERENTRY_MAIL__PROVIDER=smtp
# ORDERENTRY_MAIL__AUTH_TYPE=APP_PASSWORD
# ORDERENTRY_MAIL__HOST=smtp.example.com
# ORDERENTRY_MAIL__PORT=587
# ORDERENTRY_MAIL__SECURE=false
# ORDERENTRY_MAIL__USER=noreply@zetlab.ch
# ORDERENTRY_MAIL__PASSWORD=your-smtp-password
# ORDERENTRY_MAIL__FROM=OrderEntry <noreply@zetlab.ch>
# ORDERENTRY_MAIL__ALIAS=

# -- Gmail + App Password (erfordert 2-Faktor-Auth) ---------------------------
# ORDERENTRY_MAIL__PROVIDER=gmail
# ORDERENTRY_MAIL__AUTH_TYPE=APP_PASSWORD
# ORDERENTRY_MAIL__USER=your-account@gmail.com
# ORDERENTRY_MAIL__PASSWORD=your-16-char-app-password
# ORDERENTRY_MAIL__FROM=OrderEntry <your-account@gmail.com>

# -- Gmail + OAuth2 (produktionsgeeignet, kein Passwort) ----------------------
# ORDERENTRY_MAIL__PROVIDER=gmail
# ORDERENTRY_MAIL__AUTH_TYPE=OAUTH2
# ORDERENTRY_MAIL__USER=your-account@gmail.com
# ORDERENTRY_MAIL__OAUTH_CLIENT_ID=your-google-oauth-client-id
# ORDERENTRY_MAIL__OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# ORDERENTRY_MAIL__OAUTH_REFRESH_TOKEN=your-refresh-token
# ORDERENTRY_MAIL__FROM=OrderEntry <your-account@gmail.com>

# -- Google Workspace Relay (IP-basiert, keine Credentials nötig) -------------
# ORDERENTRY_MAIL__PROVIDER=google_workspace_relay
# ORDERENTRY_MAIL__AUTH_TYPE=NONE
# ORDERENTRY_MAIL__HOST=smtp-relay.gmail.com
# ORDERENTRY_MAIL__PORT=587
# ORDERENTRY_MAIL__FROM=OrderEntry <noreply@yourworkspace.com>
# ORDERENTRY_MAIL__DOMAIN=yourworkspace.com

# -- SMTP + OAuth2 (Microsoft Exchange Online / Office 365) -------------------
# ORDERENTRY_MAIL__PROVIDER=smtp_oauth2
# ORDERENTRY_MAIL__AUTH_TYPE=OAUTH2
# ORDERENTRY_MAIL__HOST=smtp.office365.com
# ORDERENTRY_MAIL__PORT=587
# ORDERENTRY_MAIL__USER=noreply@yourcompany.com
# ORDERENTRY_MAIL__OAUTH_CLIENT_ID=azure-client-id
# ORDERENTRY_MAIL__OAUTH_CLIENT_SECRET=azure-client-secret
# ORDERENTRY_MAIL__OAUTH_REFRESH_TOKEN=azure-refresh-token
# ORDERENTRY_MAIL__FROM=OrderEntry <noreply@yourcompany.com>


# ════════════════════════════════════════════════════════════
# LABOR / ORGANISATION  →  ORDERENTRY_LAB__*
# ════════════════════════════════════════════════════════════
# Server-seitige Lab-Konfiguration — zur Laufzeit über GET /api/env lesbar.
# Diese Werte werden für FHIR-Ressourcen, HL7-Nachrichten und Begleitscheine
# serverseitig verwendet. Fallback auf NEXT_PUBLIC_* wenn nicht gesetzt.
# ════════════════════════════════════════════════════════════

# FHIR Resource-ID der Labororganisation (server-seitig, runtime-lesbar).
# Format: FHIR-valide Zeichen [A-Za-z0-9\-\.]{1,64} — Unterstrich VERBOTEN.
# Empfehlung: <Kürzel>-<GLN>  →  eindeutig, selbstdokumentierend, FHIR-valide.
# ZLZ Zentrallabor AG: Kürzel=ZLZ, GLN=7601009336904
# WICHTIG: FHIR Organization auf HAPI muss mit  "id": "ZLZ-7601009336904"  hochgeladen sein.
ORDERENTRY_LAB__ORG_ID=ZLZ-7601009336904

# Anzeigename des Labors (server-seitig, runtime-lesbar).
# Wird in FHIR Organization.name, Begleitscheinen und HL7-Nachrichten verwendet.
ORDERENTRY_LAB__NAME=ZLZ Zentrallabor AG


# ════════════════════════════════════════════════════════════
# CLIENT-SEITIG (NEXT_PUBLIC_*)
# ════════════════════════════════════════════════════════════
# ACHTUNG: Diese Variablen behalten den NEXT_PUBLIC_* Prefix.
# Next.js baked diese beim Build in den Browser-Bundle — nicht umbenennbar.
# In Dev (npm run dev): Next.js liest diese aus .env.local beim Start.
# In Produktion (Docker): als --build-arg beim docker buildx build übergeben!
#
# Unterschied zu ORDERENTRY_LAB__*:
#   ORDERENTRY_LAB__ORG_ID  = server-seitig, runtime-lesbar via /api/env
#   NEXT_PUBLIC_LAB_ORG_ID  = client-seitig, beim Build eingebacken
#   → Beide müssen denselben Wert haben!
# ════════════════════════════════════════════════════════════

# GS1 GLN des Labors als FHIR Organization Resource-ID (client-seitig, build-time).
# Muss mit ORDERENTRY_LAB__ORG_ID übereinstimmen.
NEXT_PUBLIC_LAB_ORG_ID=ZLZ-7601009336904

# Anzeigename des Labors — UI, Tab-Titel, Begleitscheine (client-seitig, build-time).
# Muss mit ORDERENTRY_LAB__NAME übereinstimmen.
NEXT_PUBLIC_LAB_NAME=ZLZ Zentrallabor AG

# GLN-Lookup-Funktion im Benutzerprofil anzeigen (RefData SOAP).
NEXT_PUBLIC_GLN_ENABLED=true

# VeKa-Krankenversicherungskarten-Lookup anzeigen (SASIS via Orchestra).
NEXT_PUBLIC_SASIS_ENABLED=false

# Browser-only localStorage-Auth erzwingen (ignoriert Session-Cookies).
NEXT_PUBLIC_FORCE_LOCAL_AUTH=false

# Initiale Auftragstyp-Liste im UI vor dem ersten API-Response.
NEXT_PUBLIC_ORDER_SERVICE_TYPES=MIBI,ROUTINE,POC

# App-Version — wird automatisch von scripts/write-version.mjs aus Git generiert.
# NICHT manuell setzen — wird bei npm run dev / npm run build überschrieben.
# NEXT_PUBLIC_APP_VERSION=v0.1.0+118-dee7e22@main
