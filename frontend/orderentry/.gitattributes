# Default: normalize all text files
* text=auto

# Enforce LF for code and configs (important for Docker & CI)
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.env  text eol=lf
*.env.* text eol=lf

# Shell scripts MUST be LF
*.sh text eol=lf

# Docker MUST be LF — use ** to match nested paths (e.g. backend/docker/)
Dockerfile    text eol=lf
**/Dockerfile text eol=lf
**/*.yml      text eol=lf
**/*.yaml     text eol=lf

# Windows scripts
*.bat text eol=crlf

# Images / binaries untouched
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary