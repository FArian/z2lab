{
  "name": "z2lab",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "node scripts/write-version.mjs && npx prisma generate",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/write-version.mjs && npx prisma generate",
    "build": "next build",
    "prestart": "node scripts/write-version.mjs && npx prisma generate",
    "start": "next start",
    "db:studio": "npx prisma studio",
    "db:migrate:sqlite": "node scripts/run-migrations.mjs",
    "db:migrate:pg": "docker compose --profile flyway up flyway",
    "db:generate": "npx prisma generate",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^5.22.0",
    "better-sqlite3": "^12.8.0",
    "fast-xml-parser": "^5.5.10",
    "next": "^15.5.0",
    "nodemailer": "^8.0.4",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.2.6",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
